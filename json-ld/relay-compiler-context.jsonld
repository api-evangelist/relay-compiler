{
  "@context": {
    "@version": 1.1,
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "relay": "https://relay.dev/vocab/",
    "SoftwareSourceCode": {
      "@id": "schema:SoftwareSourceCode"
    },
    "GraphQLSchema": {
      "@id": "relay:GraphQLSchema",
      "@type": "@id"
    },
    "Fragment": {
      "@id": "relay:Fragment",
      "@type": "@id"
    },
    "Query": {
      "@id": "relay:Query",
      "@type": "@id"
    },
    "Mutation": {
      "@id": "relay:Mutation",
      "@type": "@id"
    },
    "Subscription": {
      "@id": "relay:Subscription",
      "@type": "@id"
    },
    "CompilerArtifact": {
      "@id": "relay:CompilerArtifact",
      "@type": "@id"
    },
    "name": {
      "@id": "schema:name"
    },
    "description": {
      "@id": "schema:description"
    },
    "version": {
      "@id": "schema:version"
    },
    "language": {
      "@id": "schema:programmingLanguage"
    },
    "schemaFile": {
      "@id": "relay:schemaFile"
    },
    "fragmentName": {
      "@id": "relay:fragmentName"
    },
    "on": {
      "@id": "relay:onType"
    },
    "directive": {
      "@id": "relay:directive"
    },
    "argument": {
      "@id": "relay:argument"
    },
    "outputType": {
      "@id": "relay:outputType"
    },
    "typegenEnabled": {
      "@id": "relay:typegenEnabled",
      "@type": "xsd:boolean"
    },
    "language": {
      "@id": "relay:typeLanguage"
    },
    "license": {
      "@id": "schema:license"
    },
    "codeRepository": {
      "@id": "schema:codeRepository"
    }
  }
}
